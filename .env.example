# ============================================
# VARIABLES DE ENTORNO - Sistema de Cobranza
# ============================================
# Copiar este archivo como .env o configurar
# directamente en el panel de Amezmo
# ============================================

# Base de Datos
DB_HOST=localhost
DB_NAME=cobranza_db
DB_USER=tu_usuario
DB_PASSWORD=tu_contraseña_segura
DB_CHARSET=utf8mb4

# Zona Horaria
TIMEZONE=America/Mexico_City

# Entorno
APP_ENV=production
APP_DEBUG=false

# Seguridad
SESSION_SECURE=true
SESSION_HTTPONLY=true

# ============================================
# INSTRUCCIONES PARA AMEZMO:
# ============================================
# 1. No subir este archivo a Git
# 2. Configurar en: Amezmo Dashboard > Settings > Environment Variables
# 3. Añadir cada variable individualmente
# 4. Después del despliegue, verificar con:
#    echo getenv('DB_HOST');
# ============================================
