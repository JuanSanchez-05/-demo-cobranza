# Configuración para Sistema de Cobranza
RewriteEngine On

# Redirigir a index.php si el archivo no existe
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Permitir acceso a archivos estáticos
RewriteCond %{REQUEST_URI} !^/demo-cobranza/assets/
RewriteCond %{REQUEST_URI} !^/demo-cobranza/index.php

# Configuración de PHP
# Desactivar display_errors en entorno demo para evitar mostrar errores al usuario
php_flag display_errors Off
php_value error_reporting 0

# Configuración de seguridad básica
<FilesMatch "\.(htaccess|htpasswd|ini|log|sh)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

